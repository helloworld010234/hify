# ============================================
# Hify 部署环境变量模板
# 复制为 .env 后修改实际值，.env 文件不进 git
# ============================================

# ---------------- 端口映射 ----------------
# 如果 80/8080 被占用，修改这里即可
FRONTEND_PORT=80
BACKEND_PORT=8080
BACKEND_MANAGE_PORT=8081

# ---------------- MySQL 配置 ----------------
# 注意：外部服务不能用 localhost，要用真实 IP
MYSQL_HOST=8.136.34.168
MYSQL_PORT=3306
MYSQL_DATABASE=hify
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# ---------------- Redis 配置 ----------------
REDIS_HOST=8.136.34.168
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ---------------- PostgreSQL / pgvector 配置 ----------------
PGVECTOR_HOST=8.136.34.168
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=myhify
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=your_pg_password

# ---------------- 文件上传 ----------------
# 宿主机目录挂载到容器的 /app/uploads
UPLOAD_DIR=./uploads

# ---------------- 外部配置（可选）----------------
# 将 application.yml 放在此目录下可覆盖内置配置
CONFIG_PATH=./config
