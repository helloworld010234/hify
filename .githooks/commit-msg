#!/usr/bin/env bash
#
# Git commit-msg hook — Hify 提交信息规范校验
# ==============================================
# 确保每次提交都遵循 Conventional Commits 格式。
#
# 安装方式：
#   git config core.hooksPath .githooks
#   chmod +x .githooks/commit-msg

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -n1 "$COMMIT_MSG_FILE")

# 颜色定义
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

# 允许的类型（与 .gitmessage 保持一致）
VALID_TYPES="feat|fix|docs|style|refactor|test|chore"

# 允许的范围（与 .gitmessage 保持一致）
VALID_SCOPES="provider|agent|chat|knowledge|workflow|mcp|common|web|infra"

# 合并提交自动放行
if echo "$COMMIT_MSG" | grep -qE '^Merge '; then
    exit 0
fi

# Revert 提交自动放行
if echo "$COMMIT_MSG" | grep -qE '^Revert '; then
    exit 0
fi

# 空提交（--allow-empty-message）放行
if [[ -z "$COMMIT_MSG" ]]; then
    echo -e "${YELLOW}⚠️  提交信息为空，建议补充描述${NC}"
    exit 0
fi

# 构建范围正则（每个范围需独立包含括号，避免 ERE 交替优先级问题）
SCOPES_PATTERN=""
IFS='|' read -ra SCOPE_ARRAY <<< "$VALID_SCOPES"
for s in "${SCOPE_ARRAY[@]}"; do
    if [[ -n "$SCOPES_PATTERN" ]]; then
        SCOPES_PATTERN="${SCOPES_PATTERN}|"
    fi
    SCOPES_PATTERN="${SCOPES_PATTERN}\\(${s}\\)"
done

# 主校验正则：type(scope): description
PATTERN="^(${VALID_TYPES})(${SCOPES_PATTERN})?: .{1,50}$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  提交信息格式错误${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo ""
    echo "当前提交信息："
    echo "  $COMMIT_MSG"
    echo ""
    echo "正确格式："
    echo -e "  ${CYAN}<类型>(<范围>): <描述>${NC}"
    echo ""
    echo "有效类型："
    echo "  feat     新功能"
    echo "  fix      Bug修复"
    echo "  docs     文档更新"
    echo "  style    代码格式（不影响功能）"
    echo "  refactor 重构"
    echo "  test     测试相关"
    echo "  chore    构建/工具/依赖变更"
    echo ""
    echo "有效范围："
    echo "  provider, agent, chat, knowledge, workflow, mcp, common, web, infra"
    echo ""
    echo "示例："
    echo "  feat(workflow): 添加工作流节点拖拽功能"
    echo "  fix(chat): 修复 SSE 连接断开未重试问题"
    echo ""
    echo -e "${YELLOW}提示：范围可省略，但类型和描述必须存在${NC}"
    echo ""
    exit 1
fi

# 检查描述是否以大写字母开头（应小写）
DESCRIPTION=$(echo "$COMMIT_MSG" | sed -E 's/^[a-z]+(\([a-z]+\))?: //')
FIRST_CHAR=$(echo "$DESCRIPTION" | cut -c1)

if echo "$FIRST_CHAR" | grep -qE '[A-Z]'; then
    echo ""
    echo -e "${YELLOW}⚠️  提交描述建议以小写字母开头${NC}"
    echo "  当前：$DESCRIPTION"
    echo "  建议：$(echo "$DESCRIPTION" | sed 's/.*/\L&/')"
    echo ""
    # 仅警告，不阻断
fi

# 检查行长度（首行不超过 50 字符，正文每行不超过 72 字符）
LINE_COUNT=$(wc -l < "$COMMIT_MSG_FILE" | tr -d ' ')
if [[ $LINE_COUNT -gt 1 ]]; then
    LINE_NO=2
    while IFS= read -r line; do
        if [[ ${#line} -gt 72 ]]; then
            echo ""
            echo -e "${YELLOW}⚠️  提交正文第 ${LINE_NO} 行超过 72 字符（当前 ${#line} 字符）${NC}"
            echo "  $line"
            echo ""
            # 仅警告，不阻断
        fi
        ((LINE_NO++)) || true
    done < <(tail -n +2 "$COMMIT_MSG_FILE")
fi

exit 0
