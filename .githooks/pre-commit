#!/usr/bin/env bash
#
# Git pre-commit hook — Hify 提交前基础检查
# ===========================================
# 在每次 git commit 前自动触发，拦截常见低级错误。
#
# 安装方式：
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

EXIT_CODE=0
WARNINGS=0

echo -e "${CYAN}═══════════════════════════════════════════════════${NC}"
echo -e "${CYAN}  Hify 提交前检查${NC}"
echo -e "${CYAN}═══════════════════════════════════════════════════${NC}"
echo ""

# ── 获取本次提交涉及的文件 ──────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
    echo -e "${GREEN}✓ 无暂存文件，跳过检查${NC}"
    exit 0
fi

# ── 1. 检查合并冲突标记 ───────────────────────────
echo "[1/5] 检查合并冲突标记..."
CONFLICT_MARKERS=$(echo "$STAGED_FILES" | xargs grep -lE '^[<>=]{7}' 2>/dev/null || true)
if [[ -n "$CONFLICT_MARKERS" ]]; then
    echo -e "${RED}✗ 发现未解决的合并冲突标记${NC}"
    echo "$CONFLICT_MARKERS" | sed 's/^/  → /'
    EXIT_CODE=1
else
    echo -e "  ${GREEN}✓ 通过${NC}"
fi

# ── 2. 检查尾随空格 ──────────────────────────────
echo "[2/5] 检查尾随空格..."
TRAILING_WHITESPACE=$(echo "$STAGED_FILES" | while IFS= read -r file; do
    [[ -f "$file" ]] || continue
    # 仅检查文本文件
    if file -b "$file" | grep -qi 'text'; then
        if grep -nE ' +$' "$file" >/dev/null 2>&1; then
            echo "$file"
        fi
    fi
done || true)

if [[ -n "$TRAILING_WHITESPACE" ]]; then
    echo -e "${YELLOW}⚠️  发现尾随空格${NC}"
    echo "$TRAILING_WHITESPACE" | sed 's/^/  → /'
    # 不阻断，仅警告
    ((WARNINGS++)) || true
else
    echo -e "  ${GREEN}✓ 通过${NC}"
fi

# ── 3. 检查大文件（> 10MB 警告，> 100MB 阻断）────
echo "[3/5] 检查大文件..."
LARGE_FILES=""
OVERSIZED_FILES=""

while IFS= read -r file; do
    [[ -f "$file" ]] || continue
    SIZE=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
    if [[ $SIZE -gt 104857600 ]]; then
        OVERSIZED_FILES="${OVERSIZED_FILES}${file} ($((SIZE/1024/1024))MB)\n"
    elif [[ $SIZE -gt 10485760 ]]; then
        LARGE_FILES="${LARGE_FILES}${file} ($((SIZE/1024/1024))MB)\n"
    fi
done <<< "$STAGED_FILES"

if [[ -n "$OVERSIZED_FILES" ]]; then
    echo -e "${RED}✗ 发现超过 100MB 的文件（Git 无法提交）${NC}"
    echo -e "$OVERSIZED_FILES" | sed 's/^/  → /'
    EXIT_CODE=1
fi

if [[ -n "$LARGE_FILES" ]]; then
    echo -e "${YELLOW}⚠️  发现超过 10MB 的文件${NC}"
    echo -e "$LARGE_FILES" | sed 's/^/  → /'
    echo "    建议：使用 Git LFS 管理大文件"
    ((WARNINGS++)) || true
fi

if [[ -z "$OVERSIZED_FILES" && -z "$LARGE_FILES" ]]; then
    echo -e "  ${GREEN}✓ 通过${NC}"
fi

# ── 4. 检查敏感文件类型 ───────────────────────────
echo "[4/5] 检查敏感文件类型..."
SENSITIVE_FILES=$(echo "$STAGED_FILES" | grep -iE '\.(pem|key|p12|pfx|crt|cer|der|env|keystore|jks)$' || true)
if [[ -n "$SENSITIVE_FILES" ]]; then
    echo -e "${RED}✗ 发现敏感文件类型（密钥/证书/.env）${NC}"
    echo "$SENSITIVE_FILES" | sed 's/^/  → /'
    echo "    建议：添加到 .gitignore，不要提交到版本库"
    EXIT_CODE=1
else
    echo -e "  ${GREEN}✓ 通过${NC}"
fi

# ── 5. 检查 IDE 本地配置 ──────────────────────────
echo "[5/5] 检查 IDE 本地配置文件..."
IDE_FILES=$(echo "$STAGED_FILES" | grep -iE '^(\.idea/|\.vscode/.*\.json|.*\.iml|\.classpath|\.project|\.settings/)' || true)
if [[ -n "$IDE_FILES" ]]; then
    echo -e "${YELLOW}⚠️  发现 IDE 本地配置文件${NC}"
    echo "$IDE_FILES" | sed 's/^/  → /'
    echo "    建议：确认是否需要提交，通常应加入 .gitignore"
    ((WARNINGS++)) || true
else
    echo -e "  ${GREEN}✓ 通过${NC}"
fi

# ── 汇总 ──────────────────────────────────────────
echo ""
echo -e "${CYAN}═══════════════════════════════════════════════════${NC}"

if [[ $EXIT_CODE -ne 0 ]]; then
    echo -e "${RED}⛔ 提交已被阻断，请修复上述问题后重试${NC}"
    echo ""
    echo "临时跳过（仅限紧急修复）："
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

if [[ $WARNINGS -gt 0 ]]; then
    echo -e "${YELLOW}⚠️  发现 ${WARNINGS} 项警告，请确认是否需要处理${NC}"
    echo ""
fi

echo -e "${GREEN}✓ 提交前检查通过${NC}"
echo -e "${CYAN}═══════════════════════════════════════════════════${NC}"
exit 0
